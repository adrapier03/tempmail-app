# App identity
APP_NAME=Temp Mail
MAIL_DOMAIN=example.com
WEB_HOST=tempmail.example.com
MAIL_HOST=mail.example.com

# Runtime
PORT=3001
NODE_ENV=production

# Host paths / deploy notes
APP_DIR=/opt/tempmail-app
PUBLIC_IP=YOUR.SERVER.IP

# Postfix pipe service name
POSTFIX_PIPE_SERVICE=tempmailpipe
POSTFIX_PIPE_TARGET=tempmail-inbox@pipe.local
POSTFIX_PIPE_DOMAIN=pipe.local
